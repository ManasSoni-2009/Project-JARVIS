# ============================================================
# J.A.R.V.I.S -- Example Environment Configuration
# Copy this to .env and fill in your API keys
# ============================================================

# --- LLM Provider (google | openai | anthropic | openrouter) ---
LLM_PROVIDER=google

# --- API Keys (set the one matching your provider) ---
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- GitHub ---
GITHUB_TOKEN=your-github-pat-here

# --- Obsidian Second Brain ---
OBSIDIAN_VAULT_PATH=D:\JARVIS MEM

# --- STT (Faster-Whisper, server-side) ---
WHISPER_MODEL_SIZE=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# --- TTS (Kokoro local neural voice) ---
TTS_VOICE=af_heart
TTS_LANG=a

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=7779

# --- Logging ---
LOG_LEVEL=INFO
